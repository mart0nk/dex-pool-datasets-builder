{
  "name": "dex-pool-datasets",
  "version": "0.1.0",
  "description": "DEX pool dataset builder and replay export adapter",
  "type": "module",
  "private": true,
  "bin": {
    "dex-pool-datasets": "./dist/cli/index.js",
    "dex-pool": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "cli": "tsx src/cli/index.ts",
    "dex-pool": "node dist/cli/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run tests"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.0.0",
    "commander": "^12.0.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
